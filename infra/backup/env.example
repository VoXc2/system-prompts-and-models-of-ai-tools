# Copy to /etc/dealix/backup.env or source from a secrets manager (never commit real values).
# Used by infra/backup/scripts/*.sh

# ── PostgreSQL (source) ─────────────────────────────────────
PGHOST=localhost
PGPORT=5432
PGUSER=salesflow
PGDATABASE=salesflow
# Prefer PGPASSFILE or ~/.pgpass in production; avoid plain PGPASSWORD in files.
# PGPASSWORD=

# ── Paths (host paths; adjust for Docker: use docker exec into db container) ──
BACKUP_ROOT=/var/lib/dealix-backups
UPLOADS_DIR=/var/lib/dealix/uploads
LOGS_DIR=/var/log/dealix
COMPOSE_PROJECT_DIR=/opt/dealix/salesflow-saas

# ── AWS S3 (primary object store) ──────────────────────────
AWS_REGION=eu-central-1
S3_BACKUP_BUCKET=dealix-prod-backups
# Optional prefix: s3://bucket/prefix/
S3_PREFIX=production/

# ── Google Cloud Storage (secondary / DR mirror) ─────────
GCS_BACKUP_BUCKET=gs://dealix-prod-backups-dr
# Service account JSON path for gsutil (or use workload identity on GKE)
# GOOGLE_APPLICATION_CREDENTIALS=/etc/dealix/gcs-backup-sa.json

# ── Encryption for env / secrets tarball (gpg symmetric) ─
BACKUP_GPG_RECIPIENT=ops@yourcompany.com
# Or symmetric only:
# BACKUP_GPG_PASSPHRASE_FILE=/root/.config/dealix/backup-gpg.pass

# ── Alerts ─────────────────────────────────────────────────
SLACK_BACKUP_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ
ALERT_EMAIL_TO=ops@yourcompany.com
# SMS via Twilio (optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
ALERT_SMS_TO=

# ── Git mirror (code backup) ───────────────────────────────
GIT_MIRROR_URL=git@github.com:yourorg/dealix-mirror.git
GIT_MIRROR_SSH_KEY=/root/.ssh/dealix_mirror_ed25519

# ── Integrity / monitoring ─────────────────────────────────
# Max allowed backup age (seconds) before verify fails
BACKUP_MAX_AGE_SEC=93600
