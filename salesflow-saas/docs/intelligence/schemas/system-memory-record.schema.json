{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dealix.internal/schemas/system-memory-record.json",
  "title": "SystemMemoryRecord",
  "type": "object",
  "required": ["tenant_id", "source", "canonical_type", "payload"],
  "properties": {
    "id": { "type": "string", "format": "uuid" },
    "tenant_id": { "type": "string", "format": "uuid" },
    "source": {
      "type": "string",
      "enum": [
        "log",
        "event",
        "api",
        "user_action",
        "message",
        "error",
        "payment",
        "task",
        "report",
        "document"
      ]
    },
    "source_table": { "type": ["string", "null"] },
    "source_id": { "type": ["string", "null"], "format": "uuid" },
    "canonical_type": {
      "type": "string",
      "description": "Stable classifier, e.g. lead.created, whatsapp.inbound, api.request.5xx"
    },
    "payload": { "type": "object", "additionalProperties": true },
    "correlation_id": { "type": ["string", "null"] },
    "dedup_key": { "type": ["string", "null"] },
    "created_at": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": false
}
