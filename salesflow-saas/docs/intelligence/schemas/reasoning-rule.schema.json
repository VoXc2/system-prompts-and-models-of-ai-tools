{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dealix.internal/schemas/reasoning-rule.json",
  "title": "ReasoningRule",
  "type": "object",
  "required": ["name", "enabled", "priority", "condition", "actions"],
  "properties": {
    "name": { "type": "string" },
    "enabled": { "type": "boolean" },
    "priority": { "type": "integer", "description": "Lower runs first" },
    "condition": {
      "type": "object",
      "description": "Evaluator DSL",
      "oneOf": [
        {
          "properties": {
            "all": {
              "type": "array",
              "items": { "$ref": "#/$defs/atom" }
            }
          }
        },
        {
          "properties": {
            "any": {
              "type": "array",
              "items": { "$ref": "#/$defs/atom" }
            }
          }
        },
        { "$ref": "#/$defs/atom" }
      ]
    },
    "actions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type"],
        "properties": {
          "type": {
            "enum": [
              "enqueue_message",
              "create_task",
              "notify_channel",
              "escalate",
              "adjust_score",
              "webhook",
              "celery_task"
            ]
          },
          "payload": { "type": "object" }
        }
      }
    },
    "risk_delta": { "type": ["integer", "null"] },
    "opportunity_delta": { "type": ["integer", "null"] }
  },
  "$defs": {
    "atom": {
      "type": "object",
      "properties": {
        "metric": { "type": "string" },
        "op": { "enum": ["eq", "ne", "gt", "gte", "lt", "lte", "in", "matches"] },
        "value": {}
      }
    }
  },
  "additionalProperties": false
}
