# Copy to .env.local for local dev. Production: set in hosting dashboard (Vercel, etc.).
# Must match the FastAPI base URL the browser can reach (CORS + strategy panel fetch).

NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# (خادم Next فقط) نفس قيمة DEALIX_INTERNAL_API_TOKEN في FastAPI — تُمرَّر تلقائياً لطلبات /api/strategy-summary و /api/marketing-hub عند إغلاق الوصول العام للـ API.
# DEALIX_INTERNAL_API_TOKEN=

# رابط حجز Google Calendar (Appointment schedules) — يفتح للزائر صفحة اختيار وقت ويولّد رابط Meet تلقائياً.
# مثال: https://calendar.app.google/xxxxxxxx
# NEXT_PUBLIC_CEO_BOOKING_URL=

# واتساب الرئيس التنفيذي (اختياري؛ الافتراضي نفس رقم الدعم إن لم يُضبط).
# NEXT_PUBLIC_CEO_WHATSAPP=966597788539

# — بوابة منطقة الشريك/المسوّق (اختياري) —
# إذا ضُبط، middleware يقيّد /marketers و /resources و /strategy و /dealix-marketing و /dealix-presentations
# حتى يُدخل الزائر الرمز في صفحة /partner-gate (كوكي httpOnly).
# اتركه فارغاً في التطوير المحلي وفي اختبارات E2E الافتراضية.
# PARTNER_GATE_SECRET=ضع_سلسلة_سرية_طويلة
